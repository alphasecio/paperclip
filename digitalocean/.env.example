# Auto-generated by deploy.sh — do not edit BETTER_AUTH_SECRET or PAPERCLIP_AGENT_JWT_SECRET manually
BETTER_AUTH_SECRET=
PAPERCLIP_AGENT_JWT_SECRET=

# Set to your domain pointing at this droplet (e.g. paperclip.yourdomain.com)
# If left empty, deploy.sh will use the droplet IP over HTTP (not recommended)
CADDY_DOMAIN=

# Auto-set by deploy.sh from CADDY_DOMAIN or droplet IP
PAPERCLIP_PUBLIC_URL=
PAPERCLIP_ALLOWED_HOSTNAMES=

# Fixed
PAPERCLIP_HOME=/paperclip
HOST=0.0.0.0
PORT=3100
NODE_ENV=production
PAPERCLIP_TELEMETRY_DISABLED=1
DO_NOT_TRACK=1

# Set to true after creating your admin account to disable further sign-ups
PAPERCLIP_AUTH_DISABLE_SIGN_UP=

# LLM provider keys — add at least one before running agents
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
